# --- Application Config ---
# The target URL for E2E tests
URL_TO_TEST=http://localhost:3000

# Project name for LambdaTest dashboard
PROJECT_NAME=ASI Wallet Automation

# --- LambdaTest Credentials ---
# Get these from https://accounts.lambdatest.com/detail/profile
LT_USER_NAME=your_username
LT_ACCESS_KEY=your_access_key

# LambdaTest API Endpoint
LT_API_URL=https://api.lambdatest.com/automation/api/v1

# --- Test Data ---
# Private key for wallet import scenarios
PRIVATE_KEY=your_test_private_key_here
